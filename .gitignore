# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/

# uv
.uv-cache/

# IDE
.vscode/
.idea/
*.swp
.DS_Store

# Logs and runtime data — these live in ~/agents/ on the host, not in the repo
logs/
*.log

# Backups — live in ~/agents/backups/ on the agent account, not in git
backups/
*.sql.gz
*.dump

# Secrets — credentials are in macOS Keychain, never in files
.env
.env.*
*.pem
*.key
secrets/

# OS artifacts
Thumbs.db
.Spotlight-V100
.Trashes
